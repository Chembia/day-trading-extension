{
  "manifest_version": 3,
  "name": "Fluey",
  "version": "1.0.0",
  "description": "Identify candlestick patterns using FLUEY algorithm",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://api.twelvedata.com/*",
    "https://query1.finance.yahoo.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["lineup-gallery.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
